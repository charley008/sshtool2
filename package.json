{
  "name": "sshtools",
  "displayName": "SSH Tools",
  "description": "XPLOT Tools for vscode;SSH,FTP,Remote",
  "version": "2.1.1",
  "publisher": "XPLOT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "ssh",
    "SSH",
    "tools",
    "remote",
    "workspace",
    "ftp",
    "sftp",
    "rdp",
    "vnc",
    "远程开发",
    "远程"
  ],
  "license": "SEE LICENSE IN LICENSE.md",
  "bugs": {
    "url": "https://github.com/charley008/sshtool2/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/charley008/sshtool2.git"
  },
  "badges": [],
  "icon": "resources/images/ssh.png",
  "activationEvents": [
    "onCommand:xplot.add",
    "onCommand:xplot.clearall",
    "onCommand:xplot.config",
    "onCommand:xplot.config.clipboard.import",
    "onCommand:xplot.connection.delete",
    "onCommand:xplot.connection.rdesktop",
    "onCommand:xplot.connection.terminal",
    "onCommand:xplot.connection.unlink",
    "onCommand:xplot.console.switch.off",
    "onCommand:xplot.console.switch.on",
    "onCommand:xplot.copy.name",
    "onCommand:xplot.copy.path",
    "onCommand:xplot.copy.scp.path",
    "onCommand:xplot.debug.off",
    "onCommand:xplot.debug.on",
    "onCommand:xplot.edit",
    "onCommand:xplot.file.delete",
    "onCommand:xplot.file.download",
    "onCommand:xplot.file.new",
    "onCommand:xplot.file.upload",
    "onCommand:xplot.folder.new",
    "onCommand:xplot.folder.open",
    "onCommand:xplot.forward.port",
    "onCommand:xplot.group.in",
    "onCommand:xplot.group.list",
    "onCommand:xplot.group.out",
    "onCommand:xplot.group.rename",
    "onCommand:xplot.host.copy",
    "onCommand:xplot.host.info.copy",
    "onCommand:xplot.refresh",
    "onCommand:xplot.reload",
    "onCommand:xplot.remote.management",
    "onCommand:xplot.rename",
    "onCommand:xplot.socks.port",
    "onCommand:xplot.terminal.hear",
    "onCommand:xplot.workspace.add",
    "onCommand:xplot.workspace.del",
    "onCommand:xplot.workspace.management",
    "onCommand:xplot.workspace.modify",
    "onView:xplot.manager",
    "onView:xplot.offline",
    "onView:xplot.online",
    "onView:xplot.workspace.offline",
    "onView:xplot.workspace.online"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "XPLOT Tools",
      "properties": {
        "XPLOTTools.default.PingHostTime": {
          "markdownDescription": "%xplot.properties.default.ping_host_time.title%",
          "type": "number",
          "default": 3,
          "enum": [
            3,
            5,
            10,
            15,
            30,
            45,
            60,
            90,
            120,
            180,
            240,
            300
          ]
        },
        "XPLOTTools.default.RefreshNodeTime": {
          "markdownDescription": "%xplot.properties.default.refresh_node_time.title%",
          "type": "number",
          "default": 30,
          "enum": [
            5,
            10,
            15,
            30,
            45,
            60,
            90,
            120,
            180,
            240,
            300
          ]
        },
        "XPLOTTools.default.ShowHiddenFilesAndFolders": {
          "markdownDescription": "%xplot.properties.default.show_hidden_files_and_folders.title%",
          "type": "boolean",
          "default": false,
          "enum": [
            true,
            false
          ]
        },
        "XPLOTTools.default.OpenFileMaxSize": {
          "markdownDescription": "%xplot.properties.default.open_file_max_size.title%",
          "type": "number",
          "default": 10,
          "pattern": "^(\\d+(?:\\.\\d+)?)$"
        },
        "XPLOTTools.default.ProhibitFileExt": {
          "type": "array",
          "description": "%xplot.properties.default.prohibit_file_ext.title%",
          "default": [
            ".zip",
            ".exe",
            ".tar",
            ".gz",
            ".so",
            ".run",
            ".rpm",
            ".deb",
            ".7z",
            ".jar",
            ".bin",
            ".iso",
            ".chm",
            ".rar"
          ],
          "items": {
            "type": "string"
          }
        },
        "XPLOTTools.default.SaveLocalFileTempCacheInformation": {
          "markdownDescription": "%xplot.properties.default.save_local_file_temp_cache_information.title%",
          "type": "boolean",
          "default": false,
          "enum": [
            true,
            false
          ]
        }
      }
    },
    "viewsWelcome": [
      {
        "view": "xplot.online",
        "contents": "%xplot.viewswelcome.xplot.host.contents%"
      },
      {
        "view": "xplot.offline",
        "contents": "%xplot.viewswelcome.xplot.host.contents%"
      },
      {
        "view": "xplot.manager",
        "contents": "%xplot.viewswelcome.xplot.host.contents%"
      },
      {
        "view": "xplot.workspace.online",
        "contents": "%xplot.viewswelcome.xplot.workspace.contents%"
      },
      {
        "view": "xplot.workspace.offline",
        "contents": "%xplot.viewswelcome.xplot.workspace.contents%"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "xplot-host",
          "title": "%xplot.title%",
          "icon": "resources/images/ssh.png"
        },
        {
          "id": "xplot-workspace",
          "title": "%xplot.workspace.title%",
          "icon": "resources/images/workspace.png"
        }
      ]
    },
    "views": {
      "xplot-host": [
        {
          "id": "xplot.online",
          "name": "%xplot.online.title%"
        },
        {
          "id": "xplot.offline",
          "name": "%xplot.offline.title%"
        },
        {
          "id": "xplot.manager",
          "name": "%xplot.manager.title%"
        }
      ],
      "xplot-workspace": [
        {
          "id": "xplot.workspace.online",
          "name": "%xplot.online.title%"
        },
        {
          "id": "xplot.workspace.offline",
          "name": "%xplot.offline.title%"
        }
      ]
    },
    "commands": [
      {
        "command": "xplot.add",
        "title": "%xplot.conn.add.title%",
        "category": "XPLOT",
        "icon": {
          "light": "resources/images/light/add.svg",
          "dark": "resources/images/dark/add.svg"
        }
      },
      {
        "command": "xplot.edit",
        "title": "%xplot.conn.edit.title%",
        "category": "XPLOT"
      },
      {
        "command": "xplot.reload",
        "title": "%xplot.conn.reload.title%",
        "category": "XPLOT",
        "icon": {
          "light": "resources/images/light/reload.svg",
          "dark": "resources/images/dark/reload.svg"
        }
      },
      {
        "command": "xplot.refresh",
        "title": "%xplot.conn.refresh.title%",
        "category": "XPLOT",
        "icon": {
          "light": "resources/images/light/refresh.svg",
          "dark": "resources/images/dark/refresh.svg"
        }
      },
      {
        "command": "xplot.group.list",
        "title": "%xplot.conn.group.list.title%",
        "category": "XPLOT",
        "icon": {
          "light": "resources/images/light/group.svg",
          "dark": "resources/images/dark/group.svg"
        }
      },
      {
        "command": "xplot.group.rename",
        "title": "%xplot.conn.group.rename.title%"
      },
      {
        "command": "xplot.group.in",
        "title": "%xplot.conn.group.in.title%"
      },
      {
        "command": "xplot.group.out",
        "title": "%xplot.conn.group.out.title%"
      },
      {
        "command": "xplot.config",
        "title": "%xplot.config.title%",
        "category": "XPLOT"
      },
      {
        "command": "xplot.clearall",
        "title": "%xplot.clearall.title%",
        "category": "XPLOT"
      },
      {
        "command": "xplot.console.switch.on",
        "title": "%xplot.console.switch.on.title%",
        "category": "XPLOT"
      },
      {
        "command": "xplot.console.switch.off",
        "title": "%xplot.console.switch.off.title%",
        "category": "XPLOT"
      },
      {
        "command": "xplot.debug.on",
        "title": "%xplot.debug.on.title%",
        "category": "XPLOT"
      },
      {
        "command": "xplot.debug.off",
        "title": "%xplot.debug.off.title%",
        "category": "XPLOT"
      },
      {
        "command": "xplot.config.clipboard.import",
        "title": "%xplot.config.clipboard.import%",
        "category": "XPLOT"
      },
      {
        "command": "xplot.connection.unlink",
        "title": "%xplot.conn.unlink.title%",
        "icon": {
          "light": "resources/images/light/unlink.svg",
          "dark": "resources/images/dark/unlink.svg"
        }
      },
      {
        "command": "xplot.connection.delete",
        "title": "%xplot.conn.delete.title%",
        "icon": {
          "light": "resources/images/light/delete.svg",
          "dark": "resources/images/dark/delete.svg"
        }
      },
      {
        "command": "xplot.connection.terminal",
        "title": "%xplot.conn.terminal.title%",
        "icon": {
          "light": "resources/images/light/terminal.svg",
          "dark": "resources/images/dark/terminal.svg"
        }
      },
      {
        "command": "xplot.connection.rdesktop",
        "title": "%xplot.conn.rdesktop.title%",
        "icon": {
          "light": "resources/images/light/rdesktop.svg",
          "dark": "resources/images/dark/rdesktop.svg"
        }
      },
      {
        "command": "xplot.terminal.hear",
        "title": "%xplot.conn.terminal.title%"
      },
      {
        "command": "xplot.file.new",
        "title": "%xplot.conn.newfile.title%"
      },
      {
        "command": "xplot.folder.new",
        "title": "%xplot.conn.newfolder.title%"
      },
      {
        "command": "xplot.workspace.add",
        "title": "%xplot.workspace.add.title%"
      },
      {
        "command": "xplot.workspace.del",
        "title": "%xplot.workspace.del.title%",
        "icon": {
          "light": "resources/images/light/delete.svg",
          "dark": "resources/images/dark/delete.svg"
        }
      },
      {
        "command": "xplot.workspace.modify",
        "title": "%xplot.workspace.modify.title%"
      },
      {
        "command": "xplot.remote.management",
        "title": "%xplot.remote.management.title%"
      },
      {
        "command": "xplot.copy.name",
        "title": "%xplot.conn.copy.name.title%"
      },
      {
        "command": "xplot.copy.path",
        "title": "%xplot.conn.copy.path.title%"
      },
      {
        "command": "xplot.copy.scp.path",
        "title": "%xplot.conn.copy.scp.path.title%"
      },
      {
        "command": "xplot.host.copy",
        "title": "%xplot.conn.cpsshcmd.title%"
      },
      {
        "command": "xplot.host.info.copy",
        "title": "%xplot.conn.cphostinfo.title%"
      },
      {
        "command": "xplot.forward.port",
        "title": "%xplot.conn.forwardport.title%"
      },
      {
        "command": "xplot.socks.port",
        "title": "%xplot.conn.startsp.title%"
      },
      {
        "command": "xplot.workspace.management",
        "title": "%xplot.workspace.management.title%"
      },
      {
        "command": "xplot.folder.open",
        "title": "%xplot.conn.terminal.title%"
      },
      {
        "command": "xplot.file.delete",
        "title": "%xplot.conn.deletefile.title%"
      },
      {
        "command": "xplot.rename",
        "title": "%xplot.conn.rename.title%"
      },
      {
        "command": "xplot.file.download",
        "title": "%xplot.conn.downloadfile.title%",
        "icon": "$(cloud-download)"
      },
      {
        "command": "xplot.file.upload",
        "title": "%xplot.conn.uploadfile.title%",
        "icon": "$(cloud-upload)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "xplot.reload",
          "when": "view =~ /^xplot.online$|^xplot.offline$|^xplot.manager$|^xplot.workspace.online$|^xplot.workspace.offline$/",
          "group": "navigation@0"
        },
        {
          "command": "xplot.refresh",
          "when": "view =~ /^xplot.online$|^xplot.offline$|^xplot.manager$|^xplot.workspace.online$|^xplot.workspace.offline$/",
          "group": "navigation@1"
        },
        {
          "command": "xplot.add",
          "when": "view =~ /^xplot.online$|^xplot.manager$/",
          "group": "navigation@3"
        },
        {
          "command": "xplot.group.list",
          "when": "view =~ /^xplot.online$|^xplot.offline$|^xplot.manager$|^xplot.workspace.online$|^xplot.workspace.offline$/",
          "group": "navigation@2"
        },
        {
          "command": "xplot.config",
          "when": "view =~ /^xplot.online$|^xplot.manager$/",
          "group": "2_navigation@0"
        },
        {
          "command": "xplot.config.clipboard.import",
          "when": "view =~ /^xplot.online$|^xplot.manager$/",
          "group": "3_navigation@0"
        },
        {
          "command": "xplot.clearall",
          "when": "view =~ /^xplot.online$|^xplot.manager$/",
          "group": "4_navigation@1"
        },
        {
          "command": "xplot.console.switch.on",
          "when": "view =~ /^xplot.online$|^xplot.offline$|^xplot.manager$|^xplot.workspace.online$|^xplot.workspace.offline$/ && xplot.console.switch == OFF",
          "group": "5_navigation@1"
        },
        {
          "command": "xplot.console.switch.off",
          "when": "view =~ /^xplot.online$|^xplot.offline$|^xplot.manager$|^xplot.workspace.online$|^xplot.workspace.offline$/ && xplot.console.switch == ON",
          "group": "5_navigation@1"
        },
        {
          "command": "xplot.debug.on",
          "when": "view =~ /^xplot.online$|^xplot.offline$|^xplot.manager$|^xplot.workspace.online$|^xplot.workspace.offline$/ && xplot.debug == OFF",
          "group": "6_navigation@1"
        },
        {
          "command": "xplot.debug.off",
          "when": "view =~ /^xplot.online$|^xplot.offline$|^xplot.manager$|^xplot.workspace.online$|^xplot.workspace.offline$/ && xplot.debug == ON",
          "group": "6_navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "xplot.connection.rdesktop",
          "when": "view =~ /^(xplot.online|xplot.offline|xplot.manager|xplot.workspace.online|xplot.workspace.offline)$/ && viewItem =~ /^(ssh|sshWorkSpace)$/",
          "group": "inline@0"
        },
        {
          "command": "xplot.connection.terminal",
          "when": "view =~ /^xplot.online$|^xplot.offline$|^xplot.manager$|^xplot.workspace.online$/ && viewItem =~ /^(ssh|sshWorkSpace)$/",
          "group": "inline@1"
        },
        {
          "command": "xplot.connection.unlink",
          "when": "view =~ /^(xplot.online|xplot.offline|xplot.manager|xplot.workspace.online)$/ && viewItem =~ /^(ssh|ftp|sshWorkSpace|ftpWorkSpace)$/",
          "group": "inline@2"
        },
        {
          "command": "xplot.connection.delete",
          "when": "view =~ /^xplot.online$|^xplot.offline$|^xplot.manager$/ && viewItem =~ /^(ssh|ftp|sshWorkSpace|ftpWorkSpace|group)$/",
          "group": "inline@3"
        },
        {
          "command": "xplot.workspace.del",
          "when": "view =~ /^xplot.workspace.online$|^xplot.workspace.offline$/ && viewItem =~ /^(ssh|ftp|sshWorkSpace|ftpWorkSpace)$/ ",
          "group": "inline@4"
        },
        {
          "command": "xplot.file.upload",
          "when": "view =~ /^xplot.online$|^xplot.manager$|^xplot.workspace.online$/ && viewItem =~ /^(sshFolder|sshLink|ftpFolder|ftpLink)$/",
          "group": "inline@0"
        },
        {
          "command": "xplot.file.download",
          "when": "view =~ /^xplot.online$|^xplot.manager$|^xplot.workspace.online$/ && viewItem  =~ /^(sshFolder|sshFile|ftpFolder|ftpFile)$/",
          "group": "inline@1"
        },
        {
          "command": "xplot.copy.name",
          "when": "view =~ /^xplot.online$|^xplot.manager$|^xplot.workspace.online$/ && viewItem =~ /^(sshFolder|sshLink|sshFile|ftpFolder|ftpLink|ftpFile)$/ ",
          "group": "0_copy@0"
        },
        {
          "command": "xplot.copy.path",
          "when": "view =~ /^xplot.online$|^xplot.manager$|^xplot.workspace.online$/ && viewItem =~ /^(sshFolder|sshLink|sshFile|ftpFolder|ftpLink|ftpFile)$/ ",
          "group": "0_copy@1"
        },
        {
          "command": "xplot.host.copy",
          "when": "view =~ /^xplot.online$|^xplot.offline$|^xplot.manager$|^xplot.workspace.online$/ && viewItem =~ /^(ssh|workspace|group)$/",
          "group": "0_copy@2"
        },
        {
          "command": "xplot.host.info.copy",
          "when": "view =~ /^xplot.online$|^xplot.offline$|^xplot.manager$|^xplot.workspace.online$/ && viewItem =~ /^(ssh|ftp|sshWorkSpace|ftpWorkSpace)$/",
          "group": "0_copy@3"
        },
        {
          "command": "xplot.copy.scp.path",
          "when": "view =~ /^xplot.online$|^xplot.manager$|^xplot.workspace.online$/ && viewItem =~ /^(sshFolder|sshLink|sshFile)$/ ",
          "group": "0_copy@4"
        },
        {
          "command": "xplot.file.new",
          "when": "view =~ /^xplot.online$|^xplot.manager$|^xplot.workspace.online$/ && viewItem =~ /^(ssh|ftp|sshWorkSpace|ftpWorkSpace)$/",
          "group": "1_new@0"
        },
        {
          "command": "xplot.file.new",
          "when": "view =~ /^xplot.online$|^xplot.manager$|^xplot.workspace.online$/ && viewItem =~ /(sshFolder|sshLink|ftpFolder|ftpLink)$/",
          "group": "1_new@1"
        },
        {
          "command": "xplot.folder.new",
          "when": "view =~ /^xplot.online$|^xplot.manager$|^xplot.workspace.online$/ && viewItem =~ /^(ssh|ftp|sshWorkSpace|ftpWorkSpace)$/ ",
          "group": "1_new@2"
        },
        {
          "command": "xplot.folder.new",
          "when": "view =~ /^xplot.online$|^xplot.manager$|^xplot.workspace.online$/ && viewItem =~ /^(sshFolder|sshLink|ftpFolder|ftpLink)$/ ",
          "group": "1_new@3"
        },
        {
          "command": "xplot.rename",
          "when": "view =~ /^xplot.online$|^xplot.manager|^xplot.workspace.online$/ && viewItem =~ /^(sshFolder|sshLink|sshFile|ftpFolder|ftpLink|ftpFile)$/ ",
          "group": "1_new@4"
        },
        {
          "command": "xplot.file.delete",
          "when": "view =~ /^xplot.online$|^xplot.manager$|^xplot.workspace.online$/ && viewItem =~ /^(sshFolder|sshLink|sshFile|ftpFolder|ftpLink|ftpFile)$/",
          "group": "1_new@5"
        },
        {
          "command": "xplot.file.upload",
          "when": "view =~ /^xplot.online$|^xplot.manager$|^xplot.workspace.online$/ && viewItem =~ /^(sshWorkSpace|ftpWorkSpace|sshFolder|sshLink|ftpFolder|ftpLink)$/",
          "group": "2_ud@0"
        },
        {
          "command": "xplot.file.download",
          "when": "view =~ /^xplot.online$|^xplot.manager$|^xplot.workspace.online$/ && viewItem  =~ /^(sshWorkSpace|ftpWorkSpace|sshFolder|sshLink|sshFile|ftpFolder|ftpLink|ftpFile)$/",
          "group": "2_ud@1"
        },
        {
          "command": "xplot.connection.rdesktop",
          "when": "view =~ /^(xplot.online|xplot.offline|xplot.manager|xplot.workspace.online|xplot.workspace.offline)$/ && viewItem =~ /^(ssh|sshWorkSpace)$/",
          "group": "3_remote@0"
        },
        {
          "command": "xplot.remote.management",
          "when": "view =~ /^(xplot.online|xplot.offline|xplot.manager|xplot.workspace.online|xplot.workspace.offline)$/ && viewItem =~ /^(ssh|sshWorkSpace)$/",
          "group": "3_remote@1"
        },
        {
          "command": "xplot.workspace.add",
          "when": "view =~ /^(xplot.online|xplot.manager|xplot.workspace.online)$/ && viewItem =~ /^(sshFolder|sshLink|ftpFolder|ftpLink)$/",
          "group": "4_workspace@0"
        },
        {
          "command": "xplot.workspace.modify",
          "when": "view =~ /^xplot.workspace.online$|^xplot.workspace.offline$/ && viewItem =~ /^(ssh|ftp|sshWorkSpace|ftpWorkSpace)$/ ",
          "group": "4_workspace@1"
        },
        {
          "command": "xplot.workspace.del",
          "when": "view =~ /^xplot.workspace.online$|^xplot.workspace.offline$/ && viewItem =~ /^(ssh|ftp|sshWorkSpace|ftpWorkSpace)$/ ",
          "group": "4_workspace@2"
        },
        {
          "command": "xplot.workspace.management",
          "when": "view =~ /^(xplot.online|xplot.offline|xplot.manager|xplot.workspace.online|xplot.workspace.offline)$/ && viewItem =~ /^(ssh|ftp|sshWorkSpace|ftpWorkSpace|sshFolder|sshLink|ftpFolder|ftpLink)$/",
          "group": "4_workspace@3"
        },
        {
          "command": "xplot.socks.port",
          "when": "view =~ /^(xplot.online|xplot.offline|xplot.manager|xplot.workspace.online|xplot.workspace.offline)$/ && viewItem =~ /^(ssh|sshWorkSpace)$/",
          "group": "5_forward@0"
        },
        {
          "command": "xplot.forward.port",
          "when": "view =~ /^(xplot.online|xplot.offline|xplot.manager|xplot.workspace.online|xplot.workspace.offline)$/ && viewItem =~ /^(ssh|sshWorkSpace)$/",
          "group": "5_forward@1"
        },
        {
          "command": "xplot.edit",
          "when": "view =~ /^xplot.online$|^xplot.offline$|^xplot.manager$/ && viewItem =~ /^(ssh|ftp|sshWorkSpace|ftpWorkSpace)$/",
          "group": "5_ssh@0"
        },
        {
          "command": "xplot.group.in",
          "when": "view =~ /^xplot.online$|^xplot.offline$|^xplot.manager$|^xplot.workspace.online$|^xplot.workspace.offline$/ && viewItem =~ /^group$/",
          "group": "6_group@0"
        },
        {
          "command": "xplot.group.out",
          "when": "view =~ /^xplot.online$|^xplot.offline$|^xplot.manager$|^xplot.workspace.online$|^xplot.workspace.offline$/ && viewItem =~ /^(ssh|ftp|sshWorkSpace|ftpWorkSpace)$/",
          "group": "6_group@1"
        },
        {
          "command": "xplot.group.rename",
          "when": "view =~ /^xplot.online$|^xplot.offline$|^xplot.manager$|^xplot.workspace.online$|^xplot.workspace.offline$/ && viewItem =~ /^group$/",
          "group": "6_group@2"
        },
        {
          "command": "xplot.folder.open",
          "when": "view =~ /^xplot.online$|^xplot.manager$|^xplot.workspace.online$/ && viewItem =~ /^(sshFolder|sshLink)$/",
          "group": "7_ff@0"
        },
        {
          "command": "xplot.refresh",
          "when": "view =~ /^xplot.online$|^xplot.offline$|^xplot.manager$|^xplot.workspace.online$|^xplot.workspace.offline$/ && viewItem =~ /^(ssh|ftp|sshWorkSpace|ftpWorkSpace|group|sshFolder|sshLink|sshFile|ftpFolder|ftpLink|ftpFile)$/",
          "group": "9_ff@0"
        }
      ]
    }
