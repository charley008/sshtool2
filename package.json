{
  "name": "sshtools2",
  "displayName": "SSH Tools 2",
  "description": "SSH Tools 2 for VS Code; SSH, SFTP, FTP, remote desktop, port forwarding, and jump host support",
  "version": "2.1.5",
  "publisher": "charley008",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "ssh",
    "SSH",
    "tools",
    "remote",
    "workspace",
    "ftp",
    "sftp",
    "rdp",
    "vnc",
    "远程开发",
    "远程"
  ],
  "license": "SEE LICENSE IN LICENSE.md",
  "bugs": {
    "url": "https://github.com/charley008/sshtool2/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/charley008/sshtool2.git"
  },
  "badges": [],
  "icon": "resources/images/ssh.png",
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "SSH Tools 2",
      "properties": {
        "SSHTOOLTools.default.PingHostTime": {
          "markdownDescription": "%sshtool.properties.default.ping_host_time.title%",
          "type": "number",
          "default": 3,
          "enum": [
            3,
            5,
            10,
            15,
            30,
            45,
            60,
            90,
            120,
            180,
            240,
            300
          ]
        },
        "SSHTOOLTools.default.RefreshNodeTime": {
          "markdownDescription": "%sshtool.properties.default.refresh_node_time.title%",
          "type": "number",
          "default": 30,
          "enum": [
            5,
            10,
            15,
            30,
            45,
            60,
            90,
            120,
            180,
            240,
            300
          ]
        },
        "SSHTOOLTools.default.ShowHiddenFilesAndFolders": {
          "markdownDescription": "%sshtool.properties.default.show_hidden_files_and_folders.title%",
          "type": "boolean",
          "default": false,
          "enum": [
            true,
            false
          ]
        },
        "SSHTOOLTools.default.OpenFileMaxSize": {
          "markdownDescription": "%sshtool.properties.default.open_file_max_size.title%",
          "type": "number",
          "default": 50,
          "pattern": "^(\\d+(?:\\.\\d+)?)$"
        },
        "SSHTOOLTools.default.ProhibitFileExt": {
          "type": "array",
          "description": "%sshtool.properties.default.prohibit_file_ext.title%",
          "default": [
            ".zip",
            ".exe",
            ".tar",
            ".gz",
            ".so",
            ".run",
            ".rpm",
            ".deb",
            ".7z",
            ".jar",
            ".bin",
            ".iso",
            ".chm",
            ".rar"
          ],
          "items": {
            "type": "string"
          }
        },
        "SSHTOOLTools.default.SaveLocalFileTempCacheInformation": {
          "markdownDescription": "%sshtool.properties.default.save_local_file_temp_cache_information.title%",
          "type": "boolean",
          "default": false,
          "enum": [
            true,
            false
          ]
        }
      }
    },
    "viewsWelcome": [
      {
        "view": "sshtools2.online",
        "contents": "%sshtool.viewswelcome.sshtool.host.contents%"
      },
      {
        "view": "sshtools2.offline",
        "contents": "%sshtool.viewswelcome.sshtool.host.contents%"
      },
      {
        "view": "sshtools2.manager",
        "contents": "%sshtool.viewswelcome.sshtool.host.contents%"
      },
      {
        "view": "sshtools2.workspace.online",
        "contents": "%sshtool.viewswelcome.sshtool.workspace.contents%"
      },
      {
        "view": "sshtools2.workspace.offline",
        "contents": "%sshtool.viewswelcome.sshtool.workspace.contents%"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sshtools2-host",
          "title": "%sshtool.title%",
          "icon": "resources/images/ssh.png"
        },
        {
          "id": "sshtools2-workspace",
          "title": "%sshtool.workspace.title%",
          "icon": "resources/images/workspace.png"
        }
      ]
    },
    "views": {
      "sshtools2-host": [
        {
          "id": "sshtools2.online",
          "name": "%sshtool.online.title%"
        },
        {
          "id": "sshtools2.offline",
          "name": "%sshtool.offline.title%"
        },
        {
          "id": "sshtools2.manager",
          "name": "%sshtool.manager.title%"
        }
      ],
      "sshtools2-workspace": [
        {
          "id": "sshtools2.workspace.online",
          "name": "%sshtool.online.title%"
        },
        {
          "id": "sshtools2.workspace.offline",
          "name": "%sshtool.offline.title%"
        }
      ]
    },
    "commands": [
      {
        "command": "sshtools2.add",
        "title": "%sshtool.conn.add.title%",
        "category": "SSHTOOL",
        "icon": {
          "light": "resources/images/light/add.svg",
          "dark": "resources/images/dark/add.svg"
        }
      },
      {
        "command": "sshtools2.edit",
        "title": "%sshtool.conn.edit.title%",
        "category": "SSHTOOL"
      },
      {
        "command": "sshtools2.reload",
        "title": "%sshtool.conn.reload.title%",
        "category": "SSHTOOL",
        "icon": {
          "light": "resources/images/light/reload.svg",
          "dark": "resources/images/dark/reload.svg"
        }
      },
      {
        "command": "sshtools2.refresh",
        "title": "%sshtool.conn.refresh.title%",
        "category": "SSHTOOL",
        "icon": {
          "light": "resources/images/light/refresh.svg",
          "dark": "resources/images/dark/refresh.svg"
        }
      },
      {
        "command": "sshtools2.group.list",
        "title": "%sshtool.conn.group.list.title%",
        "category": "SSHTOOL",
        "icon": {
          "light": "resources/images/light/group.svg",
          "dark": "resources/images/dark/group.svg"
        }
      },
      {
        "command": "sshtools2.group.rename",
        "title": "%sshtool.conn.group.rename.title%"
      },
      {
        "command": "sshtools2.group.in",
        "title": "%sshtool.conn.group.in.title%"
      },
      {
        "command": "sshtools2.group.out",
        "title": "%sshtool.conn.group.out.title%"
      },
      {
        "command": "sshtools2.config",
        "title": "%sshtool.config.title%",
        "category": "SSHTOOL"
      },
      {
        "command": "sshtools2.clearall",
        "title": "%sshtool.clearall.title%",
        "category": "SSHTOOL"
      },
      {
        "command": "sshtools2.console.switch.on",
        "title": "%sshtool.console.switch.on.title%",
        "category": "SSHTOOL"
      },
      {
        "command": "sshtools2.console.switch.off",
        "title": "%sshtool.console.switch.off.title%",
        "category": "SSHTOOL"
      },
      {
        "command": "sshtools2.debug.on",
        "title": "%sshtool.debug.on.title%",
        "category": "SSHTOOL"
      },
      {
        "command": "sshtools2.debug.off",
        "title": "%sshtool.debug.off.title%",
        "category": "SSHTOOL"
      },
      {
        "command": "sshtools2.connection.unlink",
        "title": "%sshtool.conn.unlink.title%",
        "icon": {
          "light": "resources/images/light/unlink.svg",
          "dark": "resources/images/dark/unlink.svg"
        }
      },
      {
        "command": "sshtools2.connection.delete",
        "title": "%sshtool.conn.delete.title%",
        "icon": {
          "light": "resources/images/light/delete.svg",
          "dark": "resources/images/dark/delete.svg"
        }
      },
      {
        "command": "sshtools2.connection.terminal",
        "title": "%sshtool.conn.terminal.title%",
        "icon": {
          "light": "resources/images/light/terminal.svg",
          "dark": "resources/images/dark/terminal.svg"
        }
      },
      {
        "command": "sshtools2.connection.rdesktop",
        "title": "%sshtool.conn.rdesktop.title%",
        "icon": {
          "light": "resources/images/light/rdesktop.svg",
          "dark": "resources/images/dark/rdesktop.svg"
        }
      },
      {
        "command": "sshtools2.terminal.hear",
        "title": "%sshtool.conn.terminal.title%"
      },
      {
        "command": "sshtools2.file.new",
        "title": "%sshtool.conn.newfile.title%"
      },
      {
        "command": "sshtools2.folder.new",
        "title": "%sshtool.conn.newfolder.title%"
      },
      {
        "command": "sshtools2.workspace.add",
        "title": "%sshtool.workspace.add.title%"
      },
      {
        "command": "sshtools2.workspace.del",
        "title": "%sshtool.workspace.del.title%",
        "icon": {
          "light": "resources/images/light/delete.svg",
          "dark": "resources/images/dark/delete.svg"
        }
      },
      {
        "command": "sshtools2.workspace.modify",
        "title": "%sshtool.workspace.modify.title%"
      },
      {
        "command": "sshtools2.remote.management",
        "title": "%sshtool.remote.management.title%"
      },
      {
        "command": "sshtools2.copy.name",
        "title": "%sshtool.conn.copy.name.title%"
      },
      {
        "command": "sshtools2.copy.path",
        "title": "%sshtool.conn.copy.path.title%"
      },
      {
        "command": "sshtools2.copy.scp.path",
        "title": "%sshtool.conn.copy.scp.path.title%"
      },
      {
        "command": "sshtools2.host.copy",
        "title": "%sshtool.conn.cpsshcmd.title%"
      },
      {
        "command": "sshtools2.forward.port",
        "title": "%sshtool.conn.forwardport.title%"
      },
      {
        "command": "sshtools2.socks.port",
        "title": "%sshtool.conn.startsp.title%"
      },
      {
        "command": "sshtools2.workspace.management",
        "title": "%sshtool.workspace.management.title%"
      },
      {
        "command": "sshtools2.folder.open",
        "title": "%sshtool.conn.terminal.title%"
      },
      {
        "command": "sshtools2.file.open",
        "title": "%sshtool.msg.api.file.open.title%"
      },
      {
        "command": "sshtools2.file.delete",
        "title": "%sshtool.conn.deletefile.title%"
      },
      {
        "command": "sshtools2.rename",
        "title": "%sshtool.conn.rename.title%"
      },
      {
        "command": "sshtools2.file.download",
        "title": "%sshtool.conn.downloadfile.title%",
        "icon": "$(cloud-download)"
      },
      {
        "command": "sshtools2.file.upload",
        "title": "%sshtool.conn.uploadfile.title%",
        "icon": "$(cloud-upload)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "sshtools2.reload",
          "when": "view =~ /^sshtools2.online$|^sshtools2.offline$|^sshtools2.manager$|^sshtools2.workspace.online$|^sshtools2.workspace.offline$/",
          "group": "navigation@0"
        },
        {
          "command": "sshtools2.refresh",
          "when": "view =~ /^sshtools2.online$|^sshtools2.offline$|^sshtools2.manager$|^sshtools2.workspace.online$|^sshtools2.workspace.offline$/",
          "group": "navigation@1"
        },
        {
          "command": "sshtools2.add",
          "when": "view =~ /^sshtools2.online$|^sshtools2.manager$/",
          "group": "navigation@3"
        },
        {
          "command": "sshtools2.group.list",
          "when": "view =~ /^sshtools2.online$|^sshtools2.offline$|^sshtools2.manager$|^sshtools2.workspace.online$|^sshtools2.workspace.offline$/",
          "group": "navigation@2"
        },
        {
          "command": "sshtools2.config",
          "when": "view =~ /^sshtools2.online$|^sshtools2.manager$/",
          "group": "2_navigation@0"
        },
        {
          "command": "sshtools2.clearall",
          "when": "view =~ /^sshtools2.online$|^sshtools2.manager$/",
          "group": "4_navigation@1"
        },
        {
          "command": "sshtools2.console.switch.on",
          "when": "view =~ /^sshtools2.online$|^sshtools2.offline$|^sshtools2.manager$|^sshtools2.workspace.online$|^sshtools2.workspace.offline$/ && sshtools2.console.switch == OFF",
          "group": "5_navigation@1"
        },
        {
          "command": "sshtools2.console.switch.off",
          "when": "view =~ /^sshtools2.online$|^sshtools2.offline$|^sshtools2.manager$|^sshtools2.workspace.online$|^sshtools2.workspace.offline$/ && sshtools2.console.switch == ON",
          "group": "5_navigation@1"
        },
        {
          "command": "sshtools2.debug.on",
          "when": "view =~ /^sshtools2.online$|^sshtools2.offline$|^sshtools2.manager$|^sshtools2.workspace.online$|^sshtools2.workspace.offline$/ && sshtools2.debug == OFF",
          "group": "6_navigation@1"
        },
        {
          "command": "sshtools2.debug.off",
          "when": "view =~ /^sshtools2.online$|^sshtools2.offline$|^sshtools2.manager$|^sshtools2.workspace.online$|^sshtools2.workspace.offline$/ && sshtools2.debug == ON",
          "group": "6_navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "sshtools2.connection.rdesktop",
          "when": "view =~ /^(sshtools2.online|sshtools2.offline|sshtools2.manager|sshtools2.workspace.online|sshtools2.workspace.offline)$/ && viewItem =~ /^(ssh|sshWorkSpace)$/",
          "group": "inline@0"
        },
        {
          "command": "sshtools2.connection.terminal",
          "when": "view =~ /^sshtools2.online$|^sshtools2.offline$|^sshtools2.manager$|^sshtools2.workspace.online$/ && viewItem =~ /^(ssh|sshWorkSpace)$/",
          "group": "inline@1"
        },
        {
          "command": "sshtools2.connection.unlink",
          "when": "view =~ /^(sshtools2.online|sshtools2.offline|sshtools2.manager|sshtools2.workspace.online)$/ && viewItem =~ /^(ssh|ftp|sshWorkSpace|ftpWorkSpace)$/",
          "group": "inline@2"
        },
        {
          "command": "sshtools2.connection.delete",
          "when": "view =~ /^sshtools2.online$|^sshtools2.offline$|^sshtools2.manager$/ && viewItem =~ /^(ssh|ftp|sshWorkSpace|ftpWorkSpace|group)$/",
          "group": "inline@3"
        },
        {
          "command": "sshtools2.workspace.del",
          "when": "view =~ /^sshtools2.workspace.online$|^sshtools2.workspace.offline$/ && viewItem =~ /^(ssh|ftp|sshWorkSpace|ftpWorkSpace)$/ ",
          "group": "inline@4"
        },
        {
          "command": "sshtools2.file.upload",
          "when": "view =~ /^sshtools2.online$|^sshtools2.manager$|^sshtools2.workspace.online$/ && viewItem =~ /^(sshFolder|sshLink|ftpFolder|ftpLink)$/",
          "group": "inline@0"
        },
        {
          "command": "sshtools2.file.download",
          "when": "view =~ /^sshtools2.online$|^sshtools2.manager$|^sshtools2.workspace.online$/ && viewItem  =~ /^(sshFolder|sshFile|ftpFolder|ftpFile)$/",
          "group": "inline@1"
        },
        {
          "command": "sshtools2.copy.name",
          "when": "view =~ /^sshtools2.online$|^sshtools2.manager$|^sshtools2.workspace.online$/ && viewItem =~ /^(sshFolder|sshLink|sshFile|ftpFolder|ftpLink|ftpFile)$/ ",
          "group": "0_copy@0"
        },
        {
          "command": "sshtools2.copy.path",
          "when": "view =~ /^sshtools2.online$|^sshtools2.manager$|^sshtools2.workspace.online$/ && viewItem =~ /^(sshFolder|sshLink|sshFile|ftpFolder|ftpLink|ftpFile)$/ ",
          "group": "0_copy@1"
        },
        {
          "command": "sshtools2.host.copy",
          "when": "view =~ /^sshtools2.online$|^sshtools2.offline$|^sshtools2.manager$|^sshtools2.workspace.online$/ && viewItem =~ /^(ssh|workspace|group)$/",
          "group": "0_copy@2"
        },
        {
          "command": "sshtools2.copy.scp.path",
          "when": "view =~ /^sshtools2.online$|^sshtools2.manager$|^sshtools2.workspace.online$/ && viewItem =~ /^(sshFolder|sshLink|sshFile)$/ ",
          "group": "0_copy@4"
        },
        {
          "command": "sshtools2.file.new",
          "when": "view =~ /^sshtools2.online$|^sshtools2.manager$|^sshtools2.workspace.online$/ && viewItem =~ /^(ssh|ftp|sshWorkSpace|ftpWorkSpace)$/",
          "group": "1_new@0"
        },
        {
          "command": "sshtools2.file.new",
          "when": "view =~ /^sshtools2.online$|^sshtools2.manager$|^sshtools2.workspace.online$/ && viewItem =~ /(sshFolder|sshLink|ftpFolder|ftpLink)$/",
          "group": "1_new@1"
        },
        {
          "command": "sshtools2.folder.new",
          "when": "view =~ /^sshtools2.online$|^sshtools2.manager$|^sshtools2.workspace.online$/ && viewItem =~ /^(ssh|ftp|sshWorkSpace|ftpWorkSpace)$/ ",
          "group": "1_new@2"
        },
        {
          "command": "sshtools2.folder.new",
          "when": "view =~ /^sshtools2.online$|^sshtools2.manager$|^sshtools2.workspace.online$/ && viewItem =~ /^(sshFolder|sshLink|ftpFolder|ftpLink)$/ ",
          "group": "1_new@3"
        },
        {
          "command": "sshtools2.rename",
          "when": "view =~ /^sshtools2.online$|^sshtools2.manager|^sshtools2.workspace.online$/ && viewItem =~ /^(sshFolder|sshLink|sshFile|ftpFolder|ftpLink|ftpFile)$/ ",
          "group": "1_new@4"
        },
        {
          "command": "sshtools2.file.delete",
          "when": "view =~ /^sshtools2.online$|^sshtools2.manager$|^sshtools2.workspace.online$/ && viewItem =~ /^(sshFolder|sshLink|sshFile|ftpFolder|ftpLink|ftpFile)$/",
          "group": "1_new@5"
        },
        {
          "command": "sshtools2.file.upload",
          "when": "view =~ /^sshtools2.online$|^sshtools2.manager$|^sshtools2.workspace.online$/ && viewItem =~ /^(sshWorkSpace|ftpWorkSpace|sshFolder|sshLink|ftpFolder|ftpLink)$/",
          "group": "2_ud@0"
        },
        {
          "command": "sshtools2.file.download",
          "when": "view =~ /^sshtools2.online$|^sshtools2.manager$|^sshtools2.workspace.online$/ && viewItem  =~ /^(sshWorkSpace|ftpWorkSpace|sshFolder|sshLink|sshFile|ftpFolder|ftpLink|ftpFile)$/",
          "group": "2_ud@1"
        },
        {
          "command": "sshtools2.connection.rdesktop",
          "when": "view =~ /^(sshtools2.online|sshtools2.offline|sshtools2.manager|sshtools2.workspace.online|sshtools2.workspace.offline)$/ && viewItem =~ /^(ssh|sshWorkSpace)$/",
          "group": "3_remote@0"
        },
        {
          "command": "sshtools2.remote.management",
          "when": "view =~ /^(sshtools2.online|sshtools2.offline|sshtools2.manager|sshtools2.workspace.online|sshtools2.workspace.offline)$/ && viewItem =~ /^(ssh|sshWorkSpace)$/",
          "group": "3_remote@1"
        },
        {
          "command": "sshtools2.workspace.add",
          "when": "view =~ /^(sshtools2.online|sshtools2.manager|sshtools2.workspace.online)$/ && viewItem =~ /^(sshFolder|sshLink|ftpFolder|ftpLink)$/",
          "group": "4_workspace@0"
        },
        {
          "command": "sshtools2.workspace.modify",
          "when": "view =~ /^sshtools2.workspace.online$|^sshtools2.workspace.offline$/ && viewItem =~ /^(ssh|ftp|sshWorkSpace|ftpWorkSpace)$/ ",
          "group": "4_workspace@1"
        },
        {
          "command": "sshtools2.workspace.del",
          "when": "view =~ /^sshtools2.workspace.online$|^sshtools2.workspace.offline$/ && viewItem =~ /^(ssh|ftp|sshWorkSpace|ftpWorkSpace)$/ ",
          "group": "4_workspace@2"
        },
        {
          "command": "sshtools2.workspace.management",
          "when": "view =~ /^(sshtools2.online|sshtools2.offline|sshtools2.manager|sshtools2.workspace.online|sshtools2.workspace.offline)$/ && viewItem =~ /^(ssh|ftp|sshWorkSpace|ftpWorkSpace|sshFolder|sshLink|ftpFolder|ftpLink)$/",
          "group": "4_workspace@3"
        },
        {
          "command": "sshtools2.socks.port",
          "when": "view =~ /^(sshtools2.online|sshtools2.offline|sshtools2.manager|sshtools2.workspace.online|sshtools2.workspace.offline)$/ && viewItem =~ /^(ssh|sshWorkSpace)$/",
          "group": "5_forward@0"
        },
        {
          "command": "sshtools2.forward.port",
          "when": "view =~ /^(sshtools2.online|sshtools2.offline|sshtools2.manager|sshtools2.workspace.online|sshtools2.workspace.offline)$/ && viewItem =~ /^(ssh|sshWorkSpace)$/",
          "group": "5_forward@1"
        },
        {
          "command": "sshtools2.edit",
          "when": "view =~ /^sshtools2.online$|^sshtools2.offline$|^sshtools2.manager$/ && viewItem =~ /^(ssh|ftp|sshWorkSpace|ftpWorkSpace)$/",
          "group": "5_ssh@0"
        },
        {
          "command": "sshtools2.group.in",
          "when": "view =~ /^sshtools2.online$|^sshtools2.offline$|^sshtools2.manager$|^sshtools2.workspace.online$|^sshtools2.workspace.offline$/ && viewItem =~ /^group$/",
          "group": "6_group@0"
        },
        {
          "command": "sshtools2.group.out",
          "when": "view =~ /^sshtools2.online$|^sshtools2.offline$|^sshtools2.manager$|^sshtools2.workspace.online$|^sshtools2.workspace.offline$/ && viewItem =~ /^(ssh|ftp|sshWorkSpace|ftpWorkSpace)$/",
          "group": "6_group@1"
        },
        {
          "command": "sshtools2.group.rename",
          "when": "view =~ /^sshtools2.online$|^sshtools2.offline$|^sshtools2.manager$|^sshtools2.workspace.online$|^sshtools2.workspace.offline$/ && viewItem =~ /^group$/",
          "group": "6_group@2"
        },
        {
          "command": "sshtools2.folder.open",
          "when": "view =~ /^sshtools2.online$|^sshtools2.manager$|^sshtools2.workspace.online$/ && viewItem =~ /^(sshFolder|sshLink)$/",
          "group": "7_ff@0"
        },
        {
          "command": "sshtools2.refresh",
          "when": "view =~ /^sshtools2.online$|^sshtools2.offline$|^sshtools2.manager$|^sshtools2.workspace.online$|^sshtools2.workspace.offline$/ && viewItem =~ /^(ssh|ftp|sshWorkSpace|ftpWorkSpace|group|sshFolder|sshLink|sshFile|ftpFolder|ftpLink|ftpFile)$/",
          "group": "9_ff@0"
        }
      ]
    }
  },
